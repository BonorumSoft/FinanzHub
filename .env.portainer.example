# =============================================================================
# FinanzHub - Umgebungsvariablen für Portainer
# =============================================================================
# Diese Datei dient als Referenz für die Environment-Variablen,
# die in Portainer unter "Stacks → finanzhub → Environment" gesetzt werden.
#
# In Portainer:
#   Stacks → finanzhub → Editor → "Environment variables" Sektion
#   (oder beim Erstellen unter "Use environment variables")
#
# Generiere ein starkes Passwort:
#   openssl rand -hex 16
# =============================================================================

# --- PFLICHT: Datenbank-Passwort (mindestens 16 Zeichen) -------------------
DB_PASSWORD=bitte_mit_openssl_rand_hex_16_ersetzen

# --- Optional: Log-Level (DEBUG, INFO, WARNING, ERROR) ---------------------
LOG_LEVEL=INFO

# --- Optional: Zeitzone (für Cron-Jobs und Datums-Logs) --------------------
TZ=Europe/Berlin

# --- Optional: Image-Override (default: ghcr.io/bonorumsoft/finanzhub:latest)
# Setze z. B. finanzhub:0.1.0 für eine bestimmte Version
# FINANZHUB_IMAGE=ghcr.io/bonorumsoft/finanzhub:0.1.0

# --- Optional: SMTP / Mail-Versand -----------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=finanzhub@example.com
# SMTP_PASSWORD=app-passwort-vom-mail-provider
# SMTP_FROM=finanzhub@example.com

# --- Optional: enable-banking (PSD2-Bankzugang) ----------------------------
# ENABLE_BANKING_PSP_ID=00000000-0000-0000-0000-000000000000
# ENABLE_BANKING_KEY_PATH=/secrets/ebanking.pem

# --- Beleg-Inbox (IMAP + KI) -----------------------------------------------
# IMAP-Zugang zum Belege-Postfach
# INBOX_IMAP_USER=belege@example.com
# INBOX_IMAP_PASS=app-passwort-vom-mail-provider

# KI-Provider (mindestens einer; lokal = keine Keys nötig)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# SMTP für Bestätigungsmails (Bestätigung wird übersprungen, wenn leer)
# INBOX_SMTP_HOST=smtp.gmail.com
# INBOX_SMTP_PORT=587
# INBOX_SMTP_USER=finanzhub@example.com
# INBOX_SMTP_PASS=app-passwort
# INBOX_SMTP_FROM=finanzhub@example.com

# --- Optional: Initialer Admin-User (für zukünftige Web-UI) ----------------
# ADMIN_USER=admin
# ADMIN_PASSWORD=bitte_ersetzen
