# Konfigurationsverzeichnis (YAML-Dateien)
CONFIG_DIR=./config

# Export- und Output-Verzeichnis
OUTPUT_DIR=./output

# Datenbank (PostgreSQL)
DATABASE_URL=postgresql://finanzhub:finanzhub@localhost:5432/finanzhub

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=finanzhub@example.com
SMTP_TEST_RECIPIENT=test@example.com
SMTP_TEST_MODE=false

# Enable Banking (optional)
ENABLE_BANKING_KEY_ID=
ENABLE_BANKING_PRIVATE_KEY_PATH=
ENABLE_BANKING_APP_ID=
ENABLE_BANKING_BASE_URL=https://api.enablebanking.com

# OpenFIGI (optional, für ISIN->Ticker Auflösung)
OPENFIGI_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FILE=
