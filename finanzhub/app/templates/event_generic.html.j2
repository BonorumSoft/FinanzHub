{% extends "base.html.j2" %}
{% block content %}
<div style="padding:12px 16px;border-left:4px solid {% if severity == 'critical' %}#b91c1c{% elif severity == 'warning' %}#d97706{% else %}#0ea5e9{% endif %};background:{% if severity == 'critical' %}#fef2f2{% elif severity == 'warning' %}#fffbeb{% else %}#f0f9ff{% endif %};margin-bottom:16px;">
  <div style="font-weight:600;text-transform:uppercase;font-size:12px;color:{% if severity == 'critical' %}#b91c1c{% elif severity == 'warning' %}#d97706{% else %}#0ea5e9{% endif %};">{{ severity|default('info') }}</div>
  <div style="font-size:16px;margin-top:4px;">{{ title }}</div>
</div>
<p>{{ summary }}</p>
{% if details %}
<table style="width:100%;border-collapse:collapse;font-size:13px;margin-top:12px;">
  <tbody>
    {% for k, v in details.items() %}
    <tr>
      <td style="padding:6px;background:#f8fafc;width:35%;">{{ k }}</td>
      <td style="padding:6px;font-variant-numeric:tabular-nums;">{{ v }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}
{% endblock %}
